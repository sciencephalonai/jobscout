# ─── Adzuna Job Search API ────────────────────────────────────────────────────
# Register at https://developer.adzuna.com/ to obtain credentials.
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# ─── DeepSeek (job enrichment LLM via OpenAI-compatible client) ───────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ─── Google Gemini (embeddings) ──────────────────────────────────────────────
# Used for generating job description embeddings via the google-genai (Gemini
# API) SDK. NOTE: the spec's "text-embedding-005" is a *Vertex* model name and
# is NOT served by the Gemini API. With a Gemini API key, use
# gemini-embedding-001 (3072-dim) or text-embedding-004.
GOOGLE_API_KEY=your_google_api_key_here
EMBED_MODEL=gemini-embedding-001

# ─── OpenAI (fallback / additional LLM usage) ────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Weaviate Vector Store ────────────────────────────────────────────────────
# Local Docker instance (default):
WEAVIATE_URL=http://localhost:8080
# Weaviate Cloud (WCD): set BOTH to use a managed cluster instead of local.
# CLUSTER_URL is the REST endpoint (scheme optional). When both are set, the
# store connects via connect_to_weaviate_cloud and WEAVIATE_URL is ignored.
WEAVIATE_CLUSTER_URL=
WEAVIATE_API_KEY=

# ─── Enrichment Pipeline ──────────────────────────────────────────────────────
# Number of jobs processed per enrichment batch (LLM calls are batched).
ENRICH_BATCH_SIZE=20

# ─── Ingest Scheduler ─────────────────────────────────────────────────────────
# Daily auto-refresh. OFF by default — a daily crawl can exhaust the Gemini free
# embedding tier (1,000/day). Enable via Settings in the UI or set here.
SCHEDULER_ENABLED=false
# Local hour (0-23) at which the daily refresh runs when scheduler is enabled.
SCHEDULER_HOUR=6
# How often the ingest job runs (in hours).
INGEST_INTERVAL_HOURS=6

# ─── Embedding budget ─────────────────────────────────────────────────────────
# Max embeds per ingest/refresh run. Gemini free tier = 1,000 embeds/day, SHARED
# with search + resume-match — so this reserves ~half the day's quota for search.
EMBED_DAILY_BUDGET=500

# ─── Storage ──────────────────────────────────────────────────────────────────
# File path for the DuckDB relational store.
RELATIONAL_DB_PATH=./jobscout.duckdb

# ─── Weaviate backup ──────────────────────────────────────────────────────────
# When true, a Weaviate backup (scripts/export_weaviate.py -> data/weaviate_export.jsonl.gz)
# runs automatically at the end of each ingest so the local export stays fresh.
# Pure $0 download (no embedding). Off by default — back up on demand otherwise.
EXPORT_AFTER_INGEST=false

# ─── Agent ────────────────────────────────────────────────────────────────────
# Maximum retry attempts for the enrichment / agentic loop before giving up.
AGENT_MAX_ATTEMPTS=3
