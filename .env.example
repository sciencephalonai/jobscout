# ─── Adzuna Job Search API ────────────────────────────────────────────────────
# Register at https://developer.adzuna.com/ to obtain credentials.
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# ─── DeepSeek (job enrichment LLM via OpenAI-compatible client) ───────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ─── Google Generative AI (embeddings) ───────────────────────────────────────
# Used for generating job description embeddings via the google-generativeai
# (Gemini API) SDK. NOTE: the spec's "text-embedding-005" is a *Vertex* model
# name and is NOT served by the Gemini API. With a Gemini API key, use
# gemini-embedding-001 (3072-dim) or text-embedding-004. Run
# `genai.list_models()` and pick one that supports embedContent.
GOOGLE_API_KEY=your_google_api_key_here
EMBED_MODEL=gemini-embedding-001

# ─── OpenAI (fallback / additional LLM usage) ────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Weaviate Vector Store ────────────────────────────────────────────────────
# Local Docker instance (default):
WEAVIATE_URL=http://localhost:8080
# Weaviate Cloud (WCD): set BOTH to use a managed cluster instead of local.
# CLUSTER_URL is the REST endpoint (scheme optional). When both are set, the
# store connects via connect_to_weaviate_cloud and WEAVIATE_URL is ignored.
WEAVIATE_CLUSTER_URL=
WEAVIATE_API_KEY=

# ─── Enrichment Pipeline ──────────────────────────────────────────────────────
# Number of jobs processed per enrichment batch (LLM calls are batched).
ENRICH_BATCH_SIZE=20

# ─── Ingest Scheduler ─────────────────────────────────────────────────────────
# Cron expression for automatic ingestion (default: 8 AM daily).
INGEST_SCHEDULE=0 8 * * *
# Comma-separated keywords passed to adapters that require a search term.
INGEST_KEYWORDS=software engineer,data scientist,product manager,devops engineer
# Maximum new results requested per keyword per run.
INGEST_RESULTS_WANTED=50

# ─── Storage ──────────────────────────────────────────────────────────────────
# File path for the DuckDB relational store.
RELATIONAL_DB_PATH=./jobscout.duckdb

# ─── Agent ────────────────────────────────────────────────────────────────────
# Maximum retry attempts for the enrichment / agentic loop before giving up.
AGENT_MAX_ATTEMPTS=3
