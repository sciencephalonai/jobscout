# ─── Secrets / local config ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
# keep the sanitized template (this repo uses env.example)
!env.example
!.env.example

# ─── Databases / local data ───────────────────────────────────────────────────
*.duckdb
*.duckdb.wal
*conflicted copy*
# Weaviate index export (large, regenerable via scripts/export_weaviate.py)
data/*.jsonl.gz
# Snapshot backups (may contain real keys — never publish)
jobscout_BACKUP_*/

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
.coverage
htmlcov/

# ─── Node / frontend ──────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/node_modules/
*.local

# ─── Tooling / editor / OS ────────────────────────────────────────────────────
.claude/
.playwright-mcp/
.DS_Store
Icon?
*.log
